# API Keys & Bot Tokens
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here
GROQ_API_KEY=your_groq_api_key_here
TOGETHER_API_KEY=your_together_api_key_here

# Vector Database (Qdrant)
# For local container: http://qdrant:6333 (within docker network) or http://localhost:6333 (external)
# For cloud: https://xyz-example.cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Cache/Broker Database (Redis)
# For local container: redis://redis:6379/0 (within docker network) or redis://localhost:6379/0 (external)
# For cloud/Upstash: redis://default:password@xyz.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# Gmail & Pub/Sub Integration (Optional for email routing)
GMAIL_OAUTH_CREDENTIALS={"web":{"client_id":"...","client_secret":"..."}}
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/email-notifications

# Webhook Expose Configurations
WEBHOOK_BASE_URL=https://your-ngrok-or-render-url.com

# User Preferences
FORMALITY_LEVEL=3
REPLY_DELAY_MIN=30
REPLY_DELAY_MAX=120
